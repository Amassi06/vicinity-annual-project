NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Connexion Postgres (stack docker dev — port host 55432)
DATABASE_URL=postgresql://cn_app:cn_dev_password@localhost:55432/connected_neighbours?schema=public

# Connexion MongoDB (stack docker dev — port host 57017)
MONGO_URL=mongodb://cn_root:cn_dev_password@localhost:57017/connected_neighbours?authSource=admin

# Connexion Neo4j (stack docker dev — port host 57687)
NEO4J_URL=bolt://localhost:57687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cn_dev_password

# JWT (DEV — à remplacer en prod par des secrets aléatoires >=32 chars)
JWT_ACCESS_SECRET=dev-access-secret-change-me-in-prod-please-32chars+
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-in-prod-please-32chars+
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=vicinity

# Stockage PDF : minio (défaut hors test) ou local
STORAGE_BACKEND=minio
STORAGE_DIR=./storage/documents
STORAGE_MAX_PDF_BYTES=10485760

# MinIO (`make up` — API :59000, console :59001)
MINIO_ENDPOINT=http://localhost:59000
MINIO_ACCESS_KEY=cn_minio
MINIO_SECRET_KEY=cn_dev_password
MINIO_BUCKET=vicinity-documents
MINIO_REGION=us-east-1
