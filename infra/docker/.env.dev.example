# ============================================================================
# Connected Neighbours — Environnement DEV (exemple)
# Copier ce fichier vers infra/docker/.env.dev avant de lancer Docker Compose.
# ============================================================================

COMPOSE_PROJECT_NAME=cn-dev

# --- PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=connected_neighbours
POSTGRES_USER=cn_app
POSTGRES_PASSWORD=cn_dev_password
POSTGRES_HOST_PORT=55432

# --- MongoDB
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_INITDB_DATABASE=connected_neighbours
MONGO_INITDB_ROOT_USERNAME=cn_root
MONGO_INITDB_ROOT_PASSWORD=cn_dev_password
MONGO_HOST_PORT=57017

# --- Neo4j
NEO4J_HOST=neo4j
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_AUTH=neo4j/cn_dev_password
NEO4J_BOLT_HOST_PORT=57687
NEO4J_HTTP_HOST_PORT=57474

# --- MinIO (stockage PDF S3-compatible)
MINIO_ROOT_USER=cn_minio
MINIO_ROOT_PASSWORD=cn_dev_password
MINIO_API_HOST_PORT=59000
MINIO_CONSOLE_HOST_PORT=59001
